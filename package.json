{
  "name": "prl-e2e-tests",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.11.1"
  },
  "type": "module",
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@eslint/js": "^10.0.0",
    "@hmcts/playwright-common": "^1.0.39",
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.0.0",
    "axios": "^1.7.4",
    "dotenv": "^17.0.0",
    "eslint": "^10.0.0",
    "eslint-plugin-playwright": "^2.1.0",
    "jest": "^30.0.0",
    "playwright-core": "^1.60.0",
    "prettier": "^3.3.3",
    "simple-git": "^3.27.0",
    "tsx": "^4.19.4",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.8.0",
    "uuid": "^14.0.0"
  },
  "scripts": {
    "pwinstall": "yarn playwright install --with-deps",
    "setup": "yarn install && yarn get-secrets prl-aat && yarn pwinstall && yarn playwright install webkit firefox",
    "lint": "yarn prettier . --write && yarn tsc -p tsconfig.json && yarn eslint .",
    "test:changes": "yarn tsx ./e2e/common/changedTestsRunner.ts",
    "test:manageCasesSmoke": "playwright test e2e/tests/manageCases --project chromium --grep @smoke",
    "test:manageCasesChrome": "playwright test e2e/tests/manageCases --project chromium --grep @nightly",
    "test:manageCasesFirefox": "playwright test e2e/tests/manageCases --project firefox --grep @smoke",
    "test:manageCasesSafari": "playwright test e2e/tests/manageCases --project webkit --grep @smoke",
    "test:manageCasesAccessibility": "playwright test e2e/tests/manageCases --project chromium --grep @accessibility",
    "test:manageCasesVisual": "playwright test e2e/tests/manageCases --project chromium --grep @visual",
    "test:citizenSmoke": "playwright test e2e/tests/citizen --project chromium --grep @smoke",
    "test:citizenFrontendChrome": "playwright test e2e/tests/citizen --project chromium --grep @nightly",
    "test:citizenFrontendFirefox": "playwright test e2e/tests/citizen --project firefox --grep @smoke",
    "test:citizenFrontendSafari": "playwright test e2e/tests/citizen --project webkit --grep @smoke",
    "test:citizenFrontendAccessibility": "playwright test e2e/tests/citizen --project chromium --grep @accessibility",
    "start-visual-container": "docker compose run --rm playwright",
    "test:shard": "playwright test --shard=$SHARD_INDEX/$SHARD_TOTAL",
    "report:merge": "playwright merge-reports --reporter html ./all-blob-reports"
  },
  "packageManager": "yarn@4.17.0"
}
