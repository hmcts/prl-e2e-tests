def yarnBuilder = new uk.gov.hmcts.contino.YarnBuilder(this)

// Helper function to generate parallel stages
def generateParallelShards(String scriptName, String reportPrefix, int totalShards) {
    def parallelStages = [:]
    for (int i = 1; i <= totalShards; i++) {
        def shardIndex = i
        parallelStages["Shard ${shardIndex}/${totalShards}"] = {
            stage("${reportPrefix} - Shard ${shardIndex}/${totalShards}") {
                try {
                    withEnv(["SHARD_INDEX=${shardIndex}", "SHARD_TOTAL=${totalShards}"]) {
                        yarnBuilder.yarn("${scriptName} --shard=${shardIndex}/${totalShards}")
                    }
                } catch (Error) {
                    unstable(message: "${STAGE_NAME} is unstable: " + Error.toString())
                } finally {
                    stash name: "blob-report-${reportPrefix.replaceAll(' ', '-')}-${shardIndex}", includes: "blob-report/**/*", allowEmpty: true
                }
            }
        }
    }
    return parallelStages
}

// Helper function to merge and publish reports
def mergeAndPublishReports(String reportPrefix, int totalShards) {
    stage("Merge and Publish ${reportPrefix} Reports") {
        try {
            sh 'mkdir -p all-blob-reports'
            for (int i = 1; i <= totalShards; i++) {
                try {
                    unstash "blob-report-${reportPrefix.replaceAll(' ', '-')}-${i}"
                    sh "cp -r blob-report/* all-blob-reports/ || true" 
                } catch (Exception e) {
                    echo "Could not unstash blob-report-${reportPrefix.replaceAll(' ', '-')}-${i}: ${e.message}"
                }
            }
            
            yarnBuilder.yarn("playwright merge-reports --reporter html ./all-blob-reports")
            
        } catch (Error) {
             unstable(message: "Failed to merge reports for ${reportPrefix}: " + Error.toString())
        } finally {
             publishHTML([
                allowMissing: true,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: "playwright-report",
                reportFiles: 'index.html',
                reportName: "${reportPrefix} Test Report"
            ])
            sh 'rm -rf all-blob-reports blob-report playwright-report || true'
        }
    }
}

withNightlyPipeline(type, product, component, 600) {
  loadVaultSecrets(secrets)
  env.CITIZEN_FRONTEND_BASE_URL = params.CITIZEN_FRONTEND_BASE_URL
  env.MANAGE_CASES_BASE_URL = params.MANAGE_CASES_BASE_URL
  env.FUNCTIONAL_TESTS_WORKERS = params.FUNCTIONAL_TESTS_WORKERS
  enableSlackNotifications(channel)
  
  int totalShards = params.TOTAL_SHARDS.toInteger()

  afterAlways('DependencyCheckNightly') {
    stage('Delete nightly dev branch') {
      try {
        yarnBuilder.yarn('delete-nightly-dev-branch prl-e2e-tests')
      } catch (Error) {
        unstable(message: "${STAGE_NAME} is unstable: " + Error.toString())
      }
    }
    
    stage('Install Playwright Dependencies') {
        yarnBuilder.yarn('playwright install --with-deps')
    }

    stage('Generate Auth Sessions (Global Setup)') {
        try {
             // Run setup sequentially BEFORE shards start to prevent IDAM rate limits and JSON file-locking
             yarnBuilder.yarn('playwright test --project setup')
        } catch (Error) {
             unstable(message: "Global setup failed to generate auth sessions: " + Error.toString())
        }
    }

    if(params.tests || params.tag) {
      def customStages = [:]
      for (int i = 1; i <= totalShards; i++) {
        def shardIndex = i
        customStages["Custom Shard ${shardIndex}/${totalShards}"] = {
            stage("${params.tag} ${params.tests ? "custom" : ""} tests - ${params.browser} - Shard ${shardIndex}") {
                try {
                  withEnv(["SHARD_INDEX=${shardIndex}", "SHARD_TOTAL=${totalShards}"]) {
                      yarnBuilder.yarn("playwright test ${params.tests} ${params.tag ? "--grep ${params.tag}": ""} --project ${params.browser} --shard=${shardIndex}/${totalShards}")
                  }
                } catch (Error) {
                  unstable(message: "${STAGE_NAME} is unstable: " + Error.toString())
                } finally {
                   stash name: "blob-report-custom-${shardIndex}", includes: "blob-report/**/*", allowEmpty: true
                }
            }
        }
      }
      parallel customStages
      mergeAndPublishReports("${params.tag} custom tests - ${params.browser}", totalShards)
      steps.archiveArtifacts allowEmptyArchive: true, artifacts: 'reports/tests-results/CitizenFunctional/*'
      
    } else {
      if (!params.skipCitizenTests) {
        parallel generateParallelShards('test:citizenFrontendChrome', 'Citizen Chrome', totalShards)
        mergeAndPublishReports('Citizen Chrome', totalShards)

        parallel generateParallelShards('test:citizenFrontendFirefox', 'Citizen Firefox', totalShards)
        mergeAndPublishReports('Citizen Firefox', totalShards)

        parallel generateParallelShards('test:citizenFrontendSafari', 'Citizen Webkit', totalShards)
        mergeAndPublishReports('Citizen Webkit', totalShards)
        
        steps.archiveArtifacts allowEmptyArchive: true, artifacts: 'reports/tests-results/CitizenFunctional/*'
      }
      if (!params.skipManageCasesTests) {
        parallel generateParallelShards('test:manageCasesChrome', 'Manage Cases Chrome', totalShards)
        mergeAndPublishReports('Manage Cases Chrome', totalShards)

        parallel generateParallelShards('test:manageCasesFirefox', 'Manage Cases Firefox', totalShards)
        mergeAndPublishReports('Manage Cases Firefox', totalShards)

        parallel generateParallelShards('test:manageCasesSafari', 'Manage Cases Webkit', totalShards)
        mergeAndPublishReports('Manage Cases Webkit', totalShards)
        
        steps.archiveArtifacts allowEmptyArchive: true, artifacts: 'reports/tests-results/ManageCasesFunctional/*'
      }
    }
  }
}
